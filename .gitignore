## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww]in32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017 cache/options directory
.vs/
# Visual Studio 2017 auto generated files
Generated\ Files/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUNIT
*.VisualState.xml
TestResult.xml
nunit-*.xml

# Build Results of an ATL Project
[Bb]uild[Ll]og.htm

# DNX
project.lock.json
project.fragment.lock.json
artifacts/

# StyleCop
StyleCopReport.xml

# FxCop
FxCopReport.xml

# Junk
_ReSharper*/
*.ReSharper
*.jfm
.idea/

# Unix
*~
*.swp
*.swo

# Mac
.DS_Store

# Documentation
_site/

# Visual Studio Code
.vscode/

# Brain/Artifacts (if you want to exclude agent memory)
.gemini/
